# ================================================
# STRANGE SIGNALS + GardenSync — Environment Config
# ================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)

# Google Gemini API key (GardenSync AI features via proxy.py)
GEMINI_API_KEY=

# Anthropic Claude API key (GardenSync Garden Buddy via proxy.py)
CLAUDE_API_KEY=

# Proxy server port (default: 8080)
PROXY_PORT=8080
